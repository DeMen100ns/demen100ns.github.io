    "A4",
    "C5",
    "A4",
    "G4",
  ];

  const turnaround = [
    "D5",
    "E5",
    "D5",
    "C5",
    "A4",
    "G4",
    "A4",
    "C5",
    "A4",
    "G4",
    "E4",
    "G4",
    "A4",
    "C5",
    "A4",
    "G4",
  ];

  const bridge = [
    "E5",
    "D5",
    "C5",
    "A4",
    "C5",
    "D5",
    "E5",
    "D5",
    "C5",
    "A4",
    "G4",
    "A4",
    "C5",
    "A4",
    "G4",
    "E4",
    "G4",
    "A4",
    "C5",
    "D5",
    "E5",
    "G5",
    "E5",
    "D5",
    "C5",
    "D5",
    "E5",
    "D5",
    "C5",
    "A4",
    "G4",
    "A4",
  ];

  const guitarMelody = [
    ...repeatNotes(introRiff, 2),
    ...verseA,
    ...verseB,
    ...preChorus,
    ...chorusHook,
    ...chorusAnswer,
    ...turnaround,
    ...verseA,
    ...verseB,
    ...preChorus,
    ...chorusHook,
    ...chorusAnswer,
    ...bridge,
    ...repeatNotes(chorusHook, 2),
    ...chorusAnswer,
    ...repeatNotes(turnaround, 2),
  ].map(noteToFrequency);

  const getGuitarAudioContext = () => {
    const AudioContextCtor =
      window.AudioContext || guitarWindow.webkitAudioContext;
    if (!AudioContextCtor) return null;

    if (!guitarWindow.__guitarAudioContext) {
      guitarWindow.__guitarAudioContext = new AudioContextCtor();
    }

    return guitarWindow.__guitarAudioContext;
  };

  const playGuitarClick = () => {
    const audioContext = getGuitarAudioContext();
    if (!audioContext) return;

    void audioContext.resume();

    const melodyIndex = guitarWindow.__guitarMelodyIndex ?? 0;
    const frequency = guitarMelody[melodyIndex % guitarMelody.length];
    guitarWindow.__guitarMelodyIndex = melodyIndex + 1;

    const now = audioContext.currentTime;
    const output = audioContext.createGain();
    output.gain.setValueAtTime(0.0001, now);
    output.gain.exponentialRampToValueAtTime(0.22, now + 0.01);
    output.gain.exponentialRampToValueAtTime(0.0001, now + 0.34);
    output.connect(audioContext.destination);

    const filter = audioContext.createBiquadFilter();
    filter.type = "lowpass";
    filter.frequency.setValueAtTime(Math.min(frequency * 7, 4200), now);
    filter.frequency.exponentialRampToValueAtTime(frequency * 2.3, now + 0.26);
    filter.connect(output);

    [1, 2].forEach((multiplier, index) => {
      const oscillator = audioContext.createOscillator();
      const noteGain = audioContext.createGain();
      oscillator.type = index === 0 ? "triangle" : "sine";
      oscillator.frequency.setValueAtTime(frequency * multiplier, now);
      oscillator.frequency.exponentialRampToValueAtTime(
        frequency * multiplier * 0.985,
        now + 0.18,
      );
      noteGain.gain.setValueAtTime(index === 0 ? 0.9 : 0.18, now);
      oscillator.connect(noteGain);
      noteGain.connect(filter);
      oscillator.start(now);
      oscillator.stop(now + 0.36);
    });
  };

  if (!guitarWindow.__guitarSoundBound) {
    guitarWindow.__guitarSoundBound = true;
    document.addEventListener(
      "click",
      (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        if (!target.closest("[data-guitar-sound]")) return;
        playGuitarClick();
      },
      { capture: true },
    );
  }
</script>
