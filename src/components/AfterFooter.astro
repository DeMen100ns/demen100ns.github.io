  console.log(String.raw`%c ${copyright}`,'color: #f06aae;')
  console.log('%c Theme.Reimu v' + `${version}` + ' %c https://github.com/D-Sketon/astro-theme-reimu ', 'color: white; background: #f06aae; padding:5px 0;', 'padding:4px;border:1px solid #f06aae;')
</script>
